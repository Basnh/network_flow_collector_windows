    font-weight: 600;
}

body[data-theme="light"] .control-btn {
    background: rgba(255, 255, 255, 0.8);
    border-color: rgba(2, 132, 199, 0.2);
    color: #9ca3af;
}

body[data-theme="light"] .control-btn:hover {
    background: #f3f4f6;
    border-color: #0284c7;
    color: #0284c7;
}

body[data-theme="light"] .filter-buttons {
    background: rgba(255, 255, 255, 0.8);
    border-color: rgba(2, 132, 199, 0.15);
}

/* ========================================
   RESPONSIVE DESIGN
======================================== */
@media (max-width: 1400px) {
    .dashboard-grid {
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }
    
    .center-column {
        grid-column: span 2;
    }
}

@media (max-width: 1400px) {
    .metrics-grid {
        grid-template-columns: repeat(4, 1fr);
        gap: 0.5rem;
    }
    
    .metric-card {
        padding: 0.875rem;
        min-height: 130px;
    }
    
    .card-title {
        font-size: 0.65rem;
    }
    
    .metric-value {
        font-size: 1.5rem;
    }
    
    .dashboard-grid-two-col {
        gap: 0.75rem;
        padding: 0 0.75rem 0.75rem 0.75rem;
    }
    
    .radar-section-full,
    .alerts-section-full,
    .metrics-section-full {
        padding: 0 0.75rem 0.75rem 0.75rem;
    }
}

@media (max-width: 1200px) {
    .metrics-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
    }
    
    .metric-card {
        padding: 1.25rem;
        min-height: 160px;
    }
    
    .card-title {
        font-size: 0.875rem;
    }
    
    .metric-value {
        font-size: 2rem;
    }
    
    .dashboard-grid-two-col {
        grid-template-columns: 1fr;
    }
    
    .radar-section-full .radar-panel {
        height: 350px;
    }
}

@media (max-width: 900px) {
    .dashboard-grid-two-col {
        grid-template-columns: 1fr;
        padding: 1rem;
    }
    
    .metrics-grid {
        grid-template-columns: 1fr;
    }
    
    .top-status-bar {
        padding: 1rem;
        flex-direction: column;
        gap: 1rem;
    }
    
    .system-status {
        gap: 1rem;
    }
    
    .floating-actions {
        bottom: 1rem;
        right: 1rem;
    }
    
    .fab {
        width: 48px;
        height: 48px;
        font-size: 1rem;
    }
}

@media (max-width: 600px) {
    .panel-header {
        padding: 1rem;
    }
    
    .panel-body {
        padding: 1rem;
    }
    
    .status-item {
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        text-align: center;
    }
    
    .source-item {
        grid-template-columns: 1fr;
        gap: 0.75rem;
    }
    
    .source-bar {
        margin: 0;
    }
}

/* ========================================
   UTILITY ANIMATIONS
======================================== */
@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes slideInFromRight {
    from {
        transform: translateX(100%);
        opacity: 0;
    }
    to {
        transform: translateX(0);
        opacity: 1;
    }
}

@keyframes fadeOut {
    from {
        opacity: 1;
    }
    to {
        opacity: 0;
    }
}

.animate-fade-in {
    animation: fadeInUp 0.6s ease-out;
}

/* Accessibility */
@media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
    }
}
/* ========================================
   AGENTS TABLE STYLES
======================================== */
.agents-table {
    width: 100%;
}

.agents-table .table-header,
.agents-table .agent-row {
    display: grid;
    grid-template-columns: 2fr 1.5fr 1.2fr 1fr 1.2fr 1fr;
    gap: 1rem;
    padding: 0.75rem 1rem;
    align-items: center;
}

.agents-table .table-header {
    color: var(--text-accent);
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    background: rgba(56, 189, 248, 0.05);
    border-bottom: 2px solid rgba(56, 189, 248, 0.2);
}

.agents-table .table-header div[class^="col-"] {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.agents-table .agent-row {
    border-bottom: 1px solid rgba(56, 189, 248, 0.1);
    cursor: pointer;
    transition: all var(--animation-fast);
    font-size: 0.875rem;
    background: transparent !important;
}

.agents-table .agent-row:hover {
    background: rgba(56, 189, 248, 0.05);
    transform: translateX(2px);
}

/* Agent Information */
.col-agent-id .agent-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
}

.agent-hostname {
    color: var(--text-accent);
    text-decoration: none;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: all var(--animation-fast);
}

.agent-hostname:hover {
    color: var(--accent-highlight);
    text-shadow: var(--glow-blue);
}

.agent-id-short {
    color: var(--text-muted);
    font-size: 0.7rem;
    font-family: "JetBrains Mono", monospace;
}

.col-agent-ip .ip-address {
    background: rgba(56, 189, 248, 0.1);
    color: var(--text-accent);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.8rem;
    border: 1px solid rgba(56, 189, 248, 0.2);
}

/* Status Badges */
.col-agent-status .status-container {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
}

.col-agent-status .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    width: fit-content;
}

.status-badge.active {
    background: rgba(34, 197, 94, 0.15);
    color: var(--threat-low);
    border: 1px solid var(--threat-low);
    box-shadow: 0 0 10px rgba(34, 197, 94, 0.2);
}

.status-badge.isolated {
    background: rgba(239, 68, 68, 0.15);
    color: var(--threat-critical);
    border: 1px solid var(--threat-critical);
    animation: highRiskPulse 1.5s ease-in-out infinite;
}

.status-badge.offline {
    background: rgba(100, 116, 139, 0.15);
    color: var(--text-muted);
    border: 1px solid var(--text-muted);
}

.col-agent-status .status-time {
    color: var(--text-muted);
    font-size: 0.65rem;
    font-style: italic;
}

/* Threat Level */
.col-agent-threat .threat-level-container {
    display: flex;
    align-items: center;
    justify-content: center;
}

/* Time Display */
.col-agent-time .time-display {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
}

.time-display .time-main {
    color: var(--text-primary);
    font-size: 0.875rem;
    font-family: "JetBrains Mono", monospace;
}

.time-display .time-main.live {
    color: var(--threat-low);
    font-weight: 600;
}

.time-display .time-date {
    color: var(--text-muted);
    font-size: 0.7rem;
}

/* Action Buttons */
.col-agent-actions .action-buttons {
    display: flex;
    gap: 0.5rem;
    justify-content: flex-end;
}

.action-btn {
    background: var(--gradient-glass);
    border: 1px solid rgba(56, 189, 248, 0.3);
    color: var(--text-accent);
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    cursor: pointer;
    transition: all var(--animation-fast);
    font-size: 0.875rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}

.action-btn:hover {
    background: rgba(56, 189, 248, 0.2);
    border-color: var(--accent-highlight);
    transform: translateY(-2px);
    box-shadow: var(--glow-blue);
    color: var(--text-accent);
}

.action-btn.primary {
    border-color: rgba(56, 189, 248, 0.5);
}

.action-btn.danger {
    border-color: rgba(239, 68, 68, 0.5);
    color: var(--threat-critical);
}

.action-btn.danger:hover {
    background: rgba(239, 68, 68, 0.15);
    border-color: var(--threat-critical);
    box-shadow: var(--glow-red);
}

.action-btn.success {
    border-color: rgba(34, 197, 94, 0.5);
    color: var(--threat-low);
}

.action-btn.success:hover {
    background: rgba(34, 197, 94, 0.15);
    border-color: var(--threat-low);
    box-shadow: var(--glow-green);
}

/* Gray pulse for offline status */
.pulse-gray {
    animation: pulseGray 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

@keyframes pulseGray {
    0%, 100% {
        opacity: 0.5;
    }
    50% {
        opacity: 1;
    }
}

/* Red pulse for isolated/critical status */
.pulse-red {
    animation: pulseRed 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

@keyframes pulseRed {
    0%, 100% {
        box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7);
    }
    50% {
        box-shadow: 0 0 0 10px rgba(239, 68, 68, 0);
    }
}

/* Responsive Design for Agents Table */
@media (max-width: 1400px) {
    .agents-table .table-header,
    .agents-table .agent-row {
        grid-template-columns: 1.5fr 1.2fr 1fr 0.8fr 1fr 0.8fr;
        gap: 0.75rem;
        padding: 0.75rem 0.75rem;
    }
}

@media (max-width: 1024px) {
    .agents-table .table-header,
    .agents-table .agent-row {
        grid-template-columns: 2fr 1.5fr 1fr 1fr;
        gap: 0.5rem;
    }
    
    .col-agent-time,
    .col-agent-threat {
        display: none;
    }
}

@media (max-width: 768px) {
    .agents-table .table-header,
    .agents-table .agent-row {
        grid-template-columns: 1fr 1fr;
        gap: 0.5rem;
    }
    
    .col-agent-ip,
    .col-agent-status {
        display: none;
    }
    
    .col-agent-actions {
        justify-content: center;
    }
}

/* ========================================
   BOOTSTRAP MODAL OVERRIDES
   Ensure modals render above all custom panels
   (critical when panels use overflow: hidden)
======================================== */
.modal {
    z-index: 1055 !important;
}

.modal-backdrop {
    z-index: 1050 !important;
}

.modal-content {
    position: relative;
    pointer-events: all;
}

/* Fix panels with overflow:hidden - prevent clipping modal backdrop */
.threats-panel,
.radar-panel,
.traffic-panel,
.flows-panel {
    overflow: visible;
}

/* Let panel body scroll internally without blocking modals */
.threats-panel .panel-body,
.flows-panel .panel-body,
.threats-table-container {
    overflow: auto;
}

